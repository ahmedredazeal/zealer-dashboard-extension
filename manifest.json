{
  "manifest_version": 3,
  "name": "Zealer Dashboard",
  "version": "0.0.1",
  "description": "Engineer cockpit for Zeal — personal sprint progress, time logged, tickets, and reliability, in a Chrome side panel.",
  "author": "Zeal",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Zealer Dashboard"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.atlassian.net/*",
    "https://*.sentry.io/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "options_page": "settings.html",
  "minimum_chrome_version": "114"
}
